print("This is a password generator, to generate a password, enter desired password length, and it will generate a password.")

import random
import string

password_length = int(input("Enter password length: "))
available_characters = string.ascii_uppercase + string.ascii_lowercase + string.digits
generated_password = ''.join(random.choice(available_characters) for i in range(password_length))

print("Generated password: " + generated_password) 