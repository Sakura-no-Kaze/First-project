print("This is a password generator, to generate a password, enter desired password length.(must be between 10 and 32 characters)")

import random
import string

password_length = int(input("Enter password length: "))
if password_length < 10 or password_length > 32:
    print("Invalid password length. Please enter a length between 10 and 32.")
else:
    available_characters = string.ascii_uppercase + string.ascii_lowercase + string.digits + string.punctuation
    generated_password = ''.join(random.choice(available_characters) for i in range(password_length))
    print("Generated password: " + generated_password) 